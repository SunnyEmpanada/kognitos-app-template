# Supabase (https://supabase.com/dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only: seed script, /api/kognitos/* routes — never expose in the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Kognitos API (used by POST /api/kognitos/sync and refresh scripts)
KOGNITOS_BASE_URL=https://your-kognitos-host
# Use either API key or personal access token:
KOGNITOS_API_KEY=
# KOGNITOS_PAT=

KOGNITOS_ORGANIZATION_ID=
# Alias also supported:
# KOGNITOS_ORG_ID=

KOGNITOS_WORKSPACE_ID=
KOGNITOS_AUTOMATION_ID=
